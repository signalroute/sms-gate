        {
          "expr": "smsgate_outbox_depth",
          "legendFormat": "outbox depth"
        }
      ]
    },
    {
      "title": "Registration Failures / min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "rate(smsgate_registration_failures_total[5m]) * 60",
          "legendFormat": "reg failures/min"
        }
      ]
    },
    {
      "title": "Tunnel WebSocket Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },

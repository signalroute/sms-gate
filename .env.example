# sms-gate environment variables
# Copy this file to .env (or source it) and fill in the required values.
# NEVER commit a populated .env file — it is listed in .gitignore.
#
# These variables are read by the gateway at startup and override any
# matching values in config.yaml.  Sensitive values (tokens, keys) should
# ONLY be set here, never hard-coded in config.yaml.
#
# Usage:
#   cp .env.example .env
#   chmod 600 .env
#   # edit .env with your values, then:
#   source .env && ./bin/sms-gate -config configs/config.example.yaml

# ── Required ─────────────────────────────────────────────────────────────────

# Unique identifier for this gateway hardware node.
# Appears in all log lines, heartbeat events, and Prometheus labels.
GATEWAY_ID=my-gateway-001

# Cloud WebSocket endpoint.  Must use wss:// in production.
TUNNEL_URL=wss://cloud.example.com/ws/gateway

# Bearer token used during the WebSocket upgrade handshake.
# Generate with: openssl rand -hex 32
TUNNEL_TOKEN=<secret>

# ── Logging ───────────────────────────────────────────────────────────────────

# Log verbosity.  One of: debug | info | warn | error
# Default: info
LOG_LEVEL=info

# Log output format.  One of: text | json
# Use "json" in production (structured logs, journald / Loki friendly).
# Default: text
LOG_FORMAT=text

# ── Observability ─────────────────────────────────────────────────────────────

# Prometheus scrape endpoint.
# IMPORTANT: bind to loopback (127.0.0.1:9200), never 0.0.0.0.
# Default: :9200
METRICS_ADDR=:9200

# ── Modem health ──────────────────────────────────────────────────────────────

# How often (in seconds) to poll AT+CSQ for signal quality.
# Default: 30
SIGNAL_POLL_INTERVAL=30

# ── mTLS (optional) ───────────────────────────────────────────────────────────
# Enable mutual TLS for the cloud WebSocket connection.
# Leave blank to use standard server-certificate-only TLS.

# Path to the client certificate (PEM) presented to the cloud server.
CLOUD_TLS_CERT=/path/to/cert.pem

# Path to the client private key (PEM) corresponding to CLOUD_TLS_CERT.
CLOUD_TLS_KEY=/path/to/key.pem

# Path to the CA certificate (PEM) used to pin the cloud server certificate.
# If set, the gateway will reject any server certificate not signed by this CA.
CLOUD_TLS_CA=/path/to/ca.pem
